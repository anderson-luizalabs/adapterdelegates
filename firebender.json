{
  "rules": [
    "Android library AdapterDelegates - 100% Kotlin",
    "Use Kotlin coroutines, never runBlocking",
    "Semantic commits: feat:, fix:, refactor:, docs:",
    "KDoc for public APIs, @JvmField for Java interop",
    {
      "filePathMatches": "**/*Test.kt",
      "rules": [
        "MockK: mockk(relaxed = true)",
        "Robolectric for Android",
        "JUnit 4"
      ]
    },
    {
      "filePathMatches": "**/build.gradle.kts",
      "rules": [
        "Kotlin DSL + version catalog",
        "No hardcoded versions"
      ]
    }
  ],
  "ignore": [
    "**/build/**",
    "**/.gradle/**",
    "**/local.properties"
  ]
}
